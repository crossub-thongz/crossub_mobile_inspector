# Browser-side API base. '/api' is handled by app/api/[...path]/route.ts so cookies
# stay same-origin. Override only if bypassing the proxy (e.g. direct remote API).
NEXT_PUBLIC_API_URL=/api

# Server-side proxy target for the crossub_web Nest API.
# Local: http://localhost:3001 (run pnpm dev:api in crossub_web)
# Staging: https://crossub-api-staging.onrender.com
# Production: https://crossub-api.onrender.com
# No trailing slash. Do not append /api.
API_INTERNAL_URL=http://localhost:3001

# Optional cross-app links (shown in profile / footer)
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_AGENT_PORTAL_URL=http://localhost:3002

# --- LAN / Android device testing ---
# On your phone use http://<your-mac-lan-ip>:3006 (not localhost).
# Find IP: ipconfig getifaddr en0
# Extra dev origins for Next.js HMR (auto-detected LAN IPs are also allowed):
# ALLOWED_DEV_ORIGINS=192.168.0.22
# When testing tenant check-in QR codes from this machine, point at your LAN IP:
# NEXT_PUBLIC_TENANT_APP_URL=http://192.168.0.22:3003
